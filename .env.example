# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://weave:weave_dev@localhost:5432/weave?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Encryption
ENCRYPTION_KEY=32-byte-encryption-key-change-in-production

# Paystack (PSP)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Okra (Bank Aggregation)
OKRA_CLIENT_ID=okra_client_id
OKRA_SECRET=okra_secret

# Mono (Bank Aggregation - fallback)
MONO_SECRET_KEY=mono_secret_key

# LLM (for NLP)
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini

# KYC Provider
KYC_PROVIDER=youverify
YOUVERIFY_API_KEY=youverify_api_key

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
